{
    "name": "rewards-optimizer",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev --turbopack",
        "predev": "tsx scripts/sync-reward-sources.ts",
        "sync:sources": "tsx scripts/sync-reward-sources.ts",
        "prebuild": "tsx scripts/sync-reward-sources.ts",
        "build": "next build",
        "start": "next start",
        "test": "tsx --test tests/*.test.mjs",
        "lint": "eslint .",
        "typecheck": "tsc --noEmit",
        "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,scss,md}\""
    },
    "dependencies": {
        "@hookform/resolvers": "^5.4.0",
        "@radix-ui/react-slot": "^1.1.2",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "framer-motion": "^12.40.0",
        "lucide-react": "^0.479.0",
        "next": "15.3.0-canary.1",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "react-hook-form": "^7.80.0",
        "tailwind-merge": "^3.0.2",
        "tailwindcss-animate": "^1.0.7",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.3.0",
        "@eslint/js": "^9.23.0",
        "@tailwindcss/postcss": "^4",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "eslint": "^9",
        "eslint-config-next": "15.3.0-canary.1",
        "eslint-config-prettier": "^10.1.1",
        "eslint-plugin-prettier": "^5.2.3",
        "prettier": "^3.5.3",
        "tailwindcss": "^4",
        "tsx": "^4.20.3",
        "typescript": "^5"
    }
}
